-- TABLA 1: SERVIDOR_APLICACION (Datos de red)
CREATE TABLE SERVIDOR_APLICACION (
    ID_FC NUMBER PRIMARY KEY, -- ID Único (1, 2, 3...)
    NOMBRE_SERVIDOR VARCHAR2(100),
    IP_SERVIDOR VARCHAR2(50),
    ACTIVO NUMBER(1) DEFAULT 1
);

-- TABLA 2: DETALLE_SERVIDOR_APLICACION (Datos de ejecución)
CREATE TABLE DETALLE_SERVIDOR_APLICACION (
    ID_DETALLE_PK NUMBER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, -- Autoincremental real
    ID_FC NUMBER, -- Relación con la Tabla 1 (Aquí sí puedes repetir el 1)
    USUARIO_FC VARCHAR2(50),
    PASSWORD_FC VARCHAR2(50),
    RUTA_SHELL_FC VARCHAR2(255),
    SERVICIO VARCHAR2(20), -- Aquí irá: 'status', 'stop' o 'restart'
    CONSTRAINT fk_servidor_app FOREIGN KEY (ID_FC) REFERENCES SERVIDOR_APLICACION(ID_FC)
);

